# Base URL of the reading-list API. Not a secret (EXPO_PUBLIC_* is embedded in
# the app bundle) — but never put Supabase keys or other secrets here.
# Local dev: your machine's LAN IP so a device/simulator can reach the API.
# Shared/demo builds must use the HTTPS Vercel URL.
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
